---
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import { getCollection, render } from "astro:content";
import Base from "../layouts/Base.astro";

const entries = await getCollection("docs");
const sorted = entries.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
	sorted.map(async (entry) => {
		const { Content } = await render(entry);
		return { entry, Content };
	})
);

const rawMarkdown = sorted.map(entry => {
	const filePath = resolve(`./src/content/docs/${entry.id}.md`);
	const content = readFileSync(filePath, "utf-8");
	return content.replace(/^---[\s\S]*?---\n*/, "");
}).join("\n\n---\n\n");
---

<Base title="Docs" description="Documentation for the trx CLI — commands, configuration, and agent skill.">
	<div class="docs-page">
		<div class="docs-container">
			<aside class="docs-rail">
				<div class="docs-nav">
					<div class="docs-nav-label">Documentation</div>
					<nav>
						{sorted.map(entry => (
							<a href={`#${entry.id}`} class="docs-nav-link">{entry.data.title}</a>
						))}
					</nav>
					<button id="copy-all-md" class="copy-all-btn">Copy Markdown</button>
				</div>
			</aside>

			<main class="docs-body">
				{rendered.map(({ entry, Content }) => (
					<section id={entry.id} class="docs-block">
						<div class="prose">
							<Content />
						</div>
					</section>
				))}
			</main>

			<script is:inline define:vars={{ rawMarkdown }}>
				window.__docsMarkdown = rawMarkdown;
			</script>
		</div>
	</div>
</Base>

<style is:global>
	.docs-page {
		padding-top: 56px;
	}
	.docs-container {
		display: flex;
		gap: 48px;
		max-width: 960px;
		margin: 0 auto;
		padding: 40px 24px 60px;
	}

	.docs-rail {
		flex-shrink: 0;
		width: 180px;
	}
	.docs-nav {
		position: sticky;
		top: 80px;
	}
	.docs-nav-label {
		font-family: 'Geist Mono', monospace;
		font-size: 11px; font-weight: 600; text-transform: uppercase;
		letter-spacing: 0.12em; color: var(--blue); margin-bottom: 16px;
	}
	.docs-nav nav {
		display: flex; flex-direction: column; gap: 2px;
	}
	.docs-nav-link {
		font-size: 13px; color: var(--text-2); text-decoration: none;
		padding: 6px 12px; border-radius: 6px;
		border-left: 2px solid transparent;
		transition: all 150ms;
		display: block;
	}
	.docs-nav-link:hover {
		color: var(--text); background: var(--bg-alt);
		border-left-color: var(--blue);
	}

	.docs-body {
		flex: 1;
		min-width: 0;
		max-width: 680px;
	}
	.docs-block {
		padding: 32px 0;
		border-bottom: 2px dashed var(--border);
	}
	.docs-block:first-child { padding-top: 0; }
	.docs-block:last-child { border-bottom: none; }

	.copy-all-btn {
		margin-top: 20px;
		width: 100%;
		padding: 8px 12px;
		font-family: 'Geist Mono', monospace;
		font-size: 12px;
		font-weight: 500;
		color: var(--blue);
		background: var(--bg-alt);
		border: 1px dashed var(--blue);
		border-radius: 6px;
		cursor: pointer;
		transition: all 150ms;
	}
	.copy-all-btn:hover {
		background: var(--blue);
		color: var(--white);
		border-style: solid;
	}
	.copy-all-btn.copied {
		background: var(--blue);
		color: var(--white);
		border-style: solid;
	}

	@media (max-width: 768px) {
		.docs-container {
			flex-direction: column;
			padding: 24px 16px 40px;
		}
		.docs-rail { display: none; }
		.docs-body { max-width: 100%; }
	}
</style>

<script>
document.getElementById('copy-all-md')?.addEventListener('click', async (e) => {
	const btn = e.currentTarget as HTMLButtonElement;
	const md = (window as any).__docsMarkdown;
	if (!md) return;
	await navigator.clipboard.writeText(md);
	btn.textContent = 'Copied!';
	btn.classList.add('copied');
	setTimeout(() => { btn.textContent = 'Copy Markdown'; btn.classList.remove('copied'); }, 2000);
});
</script>
